{
  "name": "@nodrel-dev/n8n-nodes-ups",
  "version": "0.3.1",
  "description": "n8n community node for UPS: rating, tracking, and address validation via the UPS REST API.",
  "license": "MIT",
  "homepage": "https://github.com/nodrel-dev/n8n-nodes-ups",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "nodrel-dev",
    "email": "289239657+nodrel-dev@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nodrel-dev/n8n-nodes-ups.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/UpsOAuth2Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Ups/Ups.node.js"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@n8n/node-cli": "*",
    "@types/node": "^22.19.21",
    "eslint": "9.32.0",
    "lefthook": "^2.1.9",
    "n8n-workflow": "^2.16.0",
    "prettier": "3.6.2",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
