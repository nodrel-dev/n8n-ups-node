# @n8n/node-cli@0.35.x pins a peer of eslint@9.29.0 while the scaffold's package.json pins
# eslint@9.32.0, so a strict `npm ci` hits ERESOLVE. legacy peer-dep resolution accepts the
# (working) eslint 9.32.0 — the same resolution used locally. Dev/CI install only; this file is
# not part of the published tarball (files: dist) and does not affect end users installing the node.
legacy-peer-deps=true
